<div class="lg:hidden text-center mb-8">
  <h1 class="text-2xl font-bold gold-text tracking-wide">LUXE EVENTS</h1>
</div>

<div>
  <h2 class="text-2xl font-bold text-white">Welcome back</h2>
  <p class="text-gray-400 mt-1 text-sm">Sign in to your account to continue</p>
</div>

<div class="mt-8">
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1.5">
        <%= f.label :password, class: "block text-sm font-medium text-gray-300" %>
        <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-gold-400 hover:text-gold-300 transition-colors" %>
        <% end %>
      </div>
      <%= f.password_field :password, autocomplete: "current-password", placeholder: "Enter your password",
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2.5 cursor-pointer">
        <%= f.check_box :remember_me, class: "rounded bg-white/[0.04] border-white/[0.12] text-gold-500 focus:ring-gold-500/40 focus:ring-offset-0" %>
        <span class="text-sm text-gray-400">Keep me signed in</span>
      </label>
    <% end %>

    <%= f.submit "Sign In", class: "w-full py-3 px-4 rounded-xl bg-gradient-to-r from-gold-500 to-gold-600 text-black font-semibold hover:from-gold-400 hover:to-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:ring-offset-2 focus:ring-offset-surface-950 transition-all duration-200 cursor-pointer text-sm" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-gray-500">
    Don't have an account?
    <%= link_to "Create one free", new_registration_path(resource_name), class: "text-gold-400 hover:text-gold-300 font-medium transition-colors" %>
  </p>
</div>
