<div class="mt-6 flex flex-col items-center gap-2 text-sm">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Sign in to your account", new_session_path(resource_name), class: "text-gold-400 hover:text-gold-300 transition-colors" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Create an account", new_registration_path(resource_name), class: "text-gold-400 hover:text-gold-300 transition-colors" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-gold-400 hover:text-gold-300 transition-colors" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-gray-500 hover:text-gray-400 transition-colors" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-gray-500 hover:text-gray-400 transition-colors" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <div class="w-full border-t border-white/10 pt-4 mt-2 flex flex-col items-center gap-2">
      <%- resource_class.omniauth_providers.each do |provider| %>
        <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}",
            omniauth_authorize_path(resource_name, provider),
            data: { turbo: false },
            class: "w-full py-2.5 px-4 rounded-lg bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-gold-500/50 transition-all duration-200 cursor-pointer text-center" %>
      <% end %>
    </div>
  <% end %>
</div>
