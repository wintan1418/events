<div class="text-center mb-8">
  <h1 class="text-3xl font-bold gold-text tracking-wide">LUXE EVENTS</h1>
  <p class="text-gray-400 mt-2">Resend confirmation instructions</p>
</div>

<div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
  <p class="text-sm text-gray-400 mb-5">Enter your email address and we'll resend your confirmation instructions.</p>

  <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
          value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:border-gold-500/50 transition-all" %>
    </div>

    <%= f.submit "Resend Confirmation", class: "w-full py-2.5 px-4 rounded-lg bg-gradient-to-r from-gold-500 to-gold-600 text-white font-medium hover:from-gold-400 hover:to-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/50 transition-all duration-200 cursor-pointer" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
