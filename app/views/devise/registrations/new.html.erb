<div class="lg:hidden text-center mb-8">
  <h1 class="text-2xl font-bold gold-text tracking-wide">LUXE EVENTS</h1>
</div>

<div>
  <h2 class="text-2xl font-bold text-white">Create your account</h2>
  <p class="text-gray-400 mt-1 text-sm">Start planning extraordinary events for free</p>
</div>

<div class="mt-8">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= label_tag :company_name, "Company / Organization", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= text_field_tag "user[company_name]", params.dig(:user, :company_name), placeholder: "e.g. Sterling Events Co.", autocomplete: "organization",
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
      <p class="text-[11px] text-gray-600 mt-1">This will be your workspace name</p>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :first_name, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "First name",
            class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
      </div>
      <div>
        <%= f.label :last_name, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.text_field :last_name, autocomplete: "family-name", placeholder: "Last name",
            class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com",
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "Min. 6 characters",
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Re-enter password",
          class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all text-sm" %>
    </div>

    <div class="pt-1">
      <%= f.submit "Create Free Account", class: "w-full py-3 px-4 rounded-xl bg-gradient-to-r from-gold-500 to-gold-600 text-black font-semibold hover:from-gold-400 hover:to-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:ring-offset-2 focus:ring-offset-surface-950 transition-all duration-200 cursor-pointer text-sm" %>
    </div>

    <p class="text-[11px] text-gray-600 text-center">By creating an account, you agree to our Terms of Service and Privacy Policy.</p>
  <% end %>

  <p class="mt-5 text-center text-sm text-gray-500">
    Already have an account?
    <%= link_to "Sign in", new_session_path(resource_name), class: "text-gold-400 hover:text-gold-300 font-medium transition-colors" %>
  </p>
</div>
