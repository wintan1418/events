<table width="100%" cellpadding="0" cellspacing="0" style="background-color: #0a0a0f; padding: 40px 0;">
  <tr>
    <td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background-color: #13131a; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 40px;">
        <tr>
          <td align="center" style="padding-bottom: 24px;">
            <h1 style="color: #d4a843; font-family: 'Inter', Arial, sans-serif; font-size: 24px; font-weight: 700; letter-spacing: 2px; margin: 0;">LUXE EVENTS</h1>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: 16px;">
            <p style="color: #e5e7eb; font-family: 'Inter', Arial, sans-serif; font-size: 16px; margin: 0;">Hello, <%= @resource.email %>!</p>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: 24px;">
            <p style="color: #9ca3af; font-family: 'Inter', Arial, sans-serif; font-size: 14px; line-height: 1.6; margin: 0;">Someone has requested a link to reset your password. You can do this by clicking the button below.</p>
          </td>
        </tr>
        <tr>
          <td align="center" style="padding-bottom: 24px;">
            <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>"
               style="display: inline-block; background: linear-gradient(to right, #d4a843, #b8922e); color: #ffffff; font-family: 'Inter', Arial, sans-serif; font-size: 14px; font-weight: 600; text-decoration: none; padding: 12px 32px; border-radius: 8px;">
              Reset My Password
            </a>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: 8px;">
            <p style="color: #6b7280; font-family: 'Inter', Arial, sans-serif; font-size: 12px; line-height: 1.6; margin: 0;">If you didn't request this, please ignore this email.</p>
          </td>
        </tr>
        <tr>
          <td>
            <p style="color: #6b7280; font-family: 'Inter', Arial, sans-serif; font-size: 12px; line-height: 1.6; margin: 0;">Your password won't change until you access the link above and create a new one.</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
