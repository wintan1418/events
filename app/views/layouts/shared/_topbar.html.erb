<header class="h-16 border-b border-white/[0.06] flex items-center justify-between px-6 bg-white/[0.02] backdrop-blur-sm">
  <div class="flex items-center gap-4">
    <button class="lg:hidden text-gray-400 hover:text-white p-1.5 rounded-lg hover:bg-white/5 transition-all" data-action="click->sidebar#toggle">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
      </svg>
    </button>
    <div>
      <h2 class="text-sm font-semibold text-white"><%= content_for(:page_title) || "Dashboard" %></h2>
    </div>
  </div>

  <div class="relative flex items-center gap-3" data-controller="dropdown">
    <button data-action="click->dropdown#toggle" class="flex items-center gap-3 px-3 py-1.5 rounded-xl bg-white/[0.03] border border-white/[0.06] hover:bg-white/[0.06] hover:border-white/[0.1] transition-all cursor-pointer">
      <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-gold-400 to-gold-600 flex items-center justify-center text-black text-xs font-bold">
        <%= current_user.initials %>
      </div>
      <div class="hidden sm:block text-left">
        <p class="text-xs font-medium text-white leading-tight"><%= current_user.full_name %></p>
        <p class="text-[10px] text-gray-500 leading-tight"><%= current_user.role.humanize %></p>
      </div>
      <svg class="w-4 h-4 text-gray-500 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
    </button>

    <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-2 w-56 rounded-xl border border-white/10 shadow-2xl shadow-black/50 z-50 overflow-hidden" style="background-color: #0d1320;">
      <div class="px-4 py-3 border-b border-white/10">
        <p class="text-sm font-medium text-white truncate"><%= current_user.full_name %></p>
        <p class="text-xs text-gray-400 truncate"><%= current_user.email %></p>
      </div>
      <div class="py-1">
        <%= link_to edit_user_registration_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-white/10 hover:text-white transition-colors" do %>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          My Profile
        <% end %>
      </div>
      <div class="border-t border-white/10 py-1">
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-red-500/10 hover:text-red-400 transition-colors" do %>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
          Sign Out
        <% end %>
      </div>
    </div>
  </div>
</header>
