<!DOCTYPE html>
<html class="dark">
<head>
  <%= render "layouts/shared/head" %>
</head>
<body class="min-h-screen text-gray-100" style="background: linear-gradient(135deg, #080d18 0%, #0d1320 40%, #111827 100%)">
  <div class="flex min-h-screen" data-controller="sidebar">
    <aside class="hidden lg:flex lg:w-64 lg:flex-col fixed inset-y-0 left-0 z-30" data-sidebar-target="menu">
      <%= render "layouts/shared/sidebar_client" %>
    </aside>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%= render "layouts/shared/topbar" %>
      <%= render "layouts/shared/flash" %>
      <main class="flex-1 p-6 lg:p-8">
        <%= yield %>
      </main>
    </div>
  </div>
</body>
</html>
