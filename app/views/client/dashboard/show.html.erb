<% content_for(:page_title) { "My Event" } %>

<div class="space-y-8">
  <% if @event %>
    <!-- Event Hero -->
    <div class="relative overflow-hidden rounded-2xl border border-white/[0.06] bg-gradient-to-r from-gold-500/10 via-white/[0.03] to-transparent p-8">
      <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/5 rounded-full -translate-y-32 translate-x-32"></div>
      <div class="absolute bottom-0 right-20 w-32 h-32 bg-gold-400/5 rounded-full translate-y-16"></div>
      <div class="relative">
        <div class="flex items-center gap-3 mb-2">
          <%= render "components/badge", status: @event.status %>
          <%= render "components/badge", status: @event.event_type %>
        </div>
        <h1 class="text-3xl font-bold text-white mt-2"><%= @event.title %></h1>
        <div class="flex flex-wrap items-center gap-4 mt-3 text-sm text-gray-400">
          <% if @event.venue %>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              <span><%= @event.venue %></span>
            </div>
          <% end %>
          <% if @event.event_date %>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
              <span><%= @event.event_date.strftime("%B %d, %Y") %></span>
            </div>
          <% end %>
          <% if @event.planner %>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
              <span>Planner: <%= @event.planner.full_name %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <%= render "components/stat_card", label: "Days Until", value: @event.days_until&.positive? ? @event.days_until : "Today!",
          icon_path: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" %>
      <%= render "components/stat_card", label: "Guests Confirmed", value: @event.guest_count_confirmed,
          icon_path: "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z", color: "emerald" %>
      <%= render "components/stat_card", label: "Budget Remaining", value: number_to_currency(@event.budget_remaining),
          icon_path: "M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z", color: "blue" %>
      <%= render "components/stat_card", label: "Tasks Done", value: "#{@event.tasks_completion_percentage}%",
          icon_path: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z", color: "purple" %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Budget Overview (2/3 width) -->
      <div class="lg:col-span-2">
        <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="text-lg font-semibold text-white">Budget Overview</h3>
              <p class="text-xs text-gray-500 mt-1">Track your event spending</p>
            </div>
            <%= link_to client_event_line_items_path(@event), class: "text-sm text-gold-400 hover:text-gold-300 transition-colors" do %>
              View Details
            <% end %>
          </div>

          <%= render "components/progress_bar", percentage: @event.budget_percentage, label: "Budget Used", color: @event.budget_percentage > 90 ? "red" : @event.budget_percentage > 70 ? "amber" : "emerald" %>

          <div class="mt-6 grid grid-cols-3 gap-4">
            <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] p-4 text-center">
              <p class="text-[10px] font-medium text-gray-500 uppercase tracking-wider">Total Budget</p>
              <p class="text-lg font-bold text-white mt-1"><%= number_to_currency(@event.budget_total) %></p>
            </div>
            <div class="rounded-xl bg-gold-500/[0.05] border border-gold-500/10 p-4 text-center">
              <p class="text-[10px] font-medium text-gray-500 uppercase tracking-wider">Spent</p>
              <p class="text-lg font-bold text-gold-400 mt-1"><%= number_to_currency(@event.budget_spent) %></p>
            </div>
            <div class="rounded-xl bg-emerald-500/[0.05] border border-emerald-500/10 p-4 text-center">
              <p class="text-[10px] font-medium text-gray-500 uppercase tracking-wider">Remaining</p>
              <p class="text-lg font-bold text-emerald-400 mt-1"><%= number_to_currency(@event.budget_remaining) %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Links (1/3 width) -->
      <div class="space-y-4">
        <%= link_to client_event_guests_path(@event), class: "block rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-5 hover:border-emerald-500/20 hover:bg-emerald-500/[0.03] transition-all duration-300 group" do %>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-emerald-500/10 flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
            </div>
            <div>
              <p class="text-2xl font-bold text-white"><%= @event.guests.count %></p>
              <p class="text-xs text-gray-500">Guest List</p>
            </div>
            <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </div>
        <% end %>

        <%= link_to client_event_line_items_path(@event), class: "block rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-5 hover:border-blue-500/20 hover:bg-blue-500/[0.03] transition-all duration-300 group" do %>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
            </div>
            <div>
              <p class="text-2xl font-bold text-white"><%= @event.line_items.count %></p>
              <p class="text-xs text-gray-500">Budget Items</p>
            </div>
            <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </div>
        <% end %>

        <%= link_to client_event_timelines_path(@event), class: "block rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-5 hover:border-purple-500/20 hover:bg-purple-500/[0.03] transition-all duration-300 group" do %>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-purple-500/10 flex items-center justify-center group-hover:bg-purple-500/20 transition-colors">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="text-2xl font-bold text-white"><%= @event.timelines.count %></p>
              <p class="text-xs text-gray-500">Timeline Entries</p>
            </div>
            <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-purple-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </div>
        <% end %>
      </div>
    </div>

    <!-- RSVP Summary -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-6">RSVP Summary</h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <% rsvp_data = [
          { label: "Confirmed", count: @event.guests.where(rsvp_status: :confirmed).count, color: "emerald" },
          { label: "Pending", count: @event.guests.where(rsvp_status: :pending).count, color: "amber" },
          { label: "Declined", count: @event.guests.where(rsvp_status: :declined).count, color: "red" },
          { label: "Tentative", count: @event.guests.where(rsvp_status: :tentative).count, color: "purple" }
        ] %>
        <% rsvp_data.each do |rsvp| %>
          <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] p-4 text-center">
            <div class="w-3 h-3 rounded-full mx-auto mb-2" style="background-color: <%= theme_color(rsvp[:color], :bg) %>"></div>
            <p class="text-2xl font-bold text-white"><%= rsvp[:count] %></p>
            <p class="text-[11px] text-gray-500 mt-1"><%= rsvp[:label] %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- No Events State -->
    <div class="relative overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gold-500/[0.03] rounded-full -translate-y-48 translate-x-48"></div>
      <div class="relative text-center py-24 px-8">
        <div class="w-16 h-16 rounded-2xl bg-gold-500/10 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        </div>
        <h2 class="text-xl font-semibold text-white">No Events Yet</h2>
        <p class="text-gray-400 mt-2 max-w-md mx-auto">Your event planner will assign you to an event soon. You'll be able to track every detail from here.</p>
      </div>
    </div>
  <% end %>
</div>
