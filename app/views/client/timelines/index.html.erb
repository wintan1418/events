<% content_for(:page_title) { "Timeline - #{@event.title}" } %>

<div class="space-y-6">
  <!-- Header with Breadcrumb -->
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <%= link_to @event.title, client_event_path(@event), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
        <span class="text-gray-600">/</span>
        <span class="text-sm text-gray-400">Timeline</span>
      </div>
      <h1 class="text-2xl font-bold text-white">Day-of Timeline</h1>
      <p class="text-gray-400 mt-1"><%= @event.event_date&.strftime("%B %d, %Y") %></p>
    </div>
  </div>

  <% if @timelines.any? %>
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-gold-500/50 via-white/10 to-white/5"></div>

      <div class="space-y-6">
        <% @timelines.each do |timeline| %>
          <div class="relative flex gap-6">
            <!-- Time column -->
            <div class="flex-shrink-0 w-16 text-right pt-1">
              <p class="text-sm font-semibold text-gold-400"><%= timeline.start_time&.strftime("%l:%M %p")&.strip %></p>
              <% if timeline.end_time %>
                <p class="text-xs text-gray-500"><%= timeline.end_time.strftime("%l:%M %p").strip %></p>
              <% end %>
            </div>

            <!-- Dot on the line -->
            <div class="flex-shrink-0 w-3 h-3 mt-2 rounded-full bg-gold-500 ring-4 ring-gold-500/20 relative z-10"></div>

            <!-- Content card -->
            <div class="flex-1 glass-card hover:bg-white/[0.06] transition-all">
              <h3 class="font-semibold text-white mb-1"><%= timeline.title %></h3>

              <% if timeline.description.present? %>
                <p class="text-sm text-gray-400 mb-3"><%= timeline.description %></p>
              <% end %>

              <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500">
                <% if timeline.start_time && timeline.end_time %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <% duration_minutes = ((timeline.end_time - timeline.start_time) / 60).to_i %>
                    <% if duration_minutes >= 60 %>
                      <%= duration_minutes / 60 %>h <%= duration_minutes % 60 %>m
                    <% else %>
                      <%= duration_minutes %>m
                    <% end %>
                  </span>
                <% end %>

                <% if timeline.responsible_party.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                    </svg>
                    <%= timeline.responsible_party %>
                  </span>
                <% end %>

                <% if timeline.location.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                    </svg>
                    <%= timeline.location %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 text-center py-12">
      <svg class="w-12 h-12 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-gray-500">No timeline entries yet</p>
      <p class="text-gray-600 text-sm mt-1">Your planner will build the day-of timeline as the event approaches.</p>
    </div>
  <% end %>
</div>
