<% content_for(:page_title) { "#{@line_item.description} - #{@event.title}" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <%= link_to @event.title, client_event_path(@event), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
        <span class="text-gray-600">/</span>
        <%= link_to "Budget", client_event_line_items_path(@event), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
        <span class="text-gray-600">/</span>
        <span class="text-sm text-gray-400"><%= @line_item.description %></span>
      </div>
      <h1 class="text-2xl font-bold text-white"><%= @line_item.description %></h1>
    </div>
    <%= link_to "Back", client_event_line_items_path(@event), class: "text-sm text-gray-400 hover:text-white" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= render "components/stat_card", label: "Estimated Cost", value: number_to_currency(@line_item.estimated_cost), color: "blue" %>
    <%= render "components/stat_card", label: "Actual Cost", value: number_to_currency(@line_item.actual_cost), color: "emerald" %>
    <%= render "components/stat_card", label: "Variance", value: number_to_currency(@line_item.variance), color: @line_item.over_budget? ? "red" : "emerald" %>
  </div>

  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
    <h3 class="text-lg font-semibold text-white mb-4">Details</h3>
    <dl class="space-y-3">
      <div class="flex justify-between">
        <dt class="text-sm text-gray-400">Category</dt>
        <dd class="text-sm text-white capitalize"><%= @line_item.category %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-400">Description</dt>
        <dd class="text-sm text-white"><%= @line_item.description %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-400">Payment Status</dt>
        <dd class="text-sm">
          <% if @line_item.paid? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 ring-1 ring-inset ring-emerald-500/20">Paid</span>
          <% else %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 ring-1 ring-inset ring-amber-500/20">Unpaid</span>
          <% end %>
        </dd>
      </div>
      <% if @line_item.event_vendor %>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Vendor</dt>
          <dd class="text-sm text-white"><%= @line_item.event_vendor.vendor.name %></dd>
        </div>
      <% end %>
      <% if @line_item.notes.present? %>
        <div>
          <dt class="text-sm text-gray-400 mb-1">Notes</dt>
          <dd class="text-sm text-white"><%= @line_item.notes %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
