<% content_for(:page_title) { "Edit Guest - #{@guest.full_name}" } %>

<div class="max-w-2xl">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to @event.title, client_event_path(@event), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
    <span class="text-gray-600">/</span>
    <%= link_to "Guests", client_event_guests_path(@event), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
    <span class="text-gray-600">/</span>
    <span class="text-sm text-gray-400">Edit</span>
  </div>
  <h1 class="text-2xl font-bold text-white mb-6">Edit Guest</h1>
  <%= render "form", guest: @guest %>
</div>
