<% content_for(:page_title) { "Guest List - #{@event.title}" } %>

<div class="space-y-6">
  <!-- Header with Breadcrumb -->
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <%= link_to @event.title, client_event_path(@event), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
        <span class="text-gray-600">/</span>
        <span class="text-sm text-gray-400">Guests</span>
      </div>
      <h1 class="text-2xl font-bold text-white">Guest List</h1>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to new_client_event_guest_path(@event), class: "px-4 py-2 rounded-lg bg-gradient-to-r from-gold-500 to-gold-600 text-white text-sm font-medium hover:from-gold-400 hover:to-gold-500 transition-all" do %>
        + Add Guest
      <% end %>
    </div>
  </div>

  <!-- RSVP Summary Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <%= render "components/stat_card", label: "Total Guests", value: @guests.size,
        icon_path: "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" %>
    <%= render "components/stat_card", label: "Confirmed", value: @guests.select(&:confirmed?).size, color: "emerald" %>
    <%= render "components/stat_card", label: "Declined", value: @guests.select(&:declined?).size, color: "red" %>
    <%= render "components/stat_card", label: "Pending", value: @guests.select(&:pending?).size, color: "amber" %>
  </div>

  <!-- Guest Table -->
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
    <% if @guests.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">RSVP Status</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-center">Party Size</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Dietary Notes</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-center">Table #</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="">
            <% @guests.each do |guest| %>
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-3.5">
                  <span class="font-medium text-white"><%= guest.full_name %></span>
                </td>
                <td class="px-6 py-3.5 text-gray-400"><%= guest.email || "---" %></td>
                <td class="px-6 py-3.5"><%= render "components/badge", status: guest.rsvp_status %></td>
                <td class="px-6 py-3.5 text-gray-400 text-center"><%= guest.party_size %></td>
                <td class="px-6 py-3.5 text-gray-400 text-sm max-w-[200px] truncate"><%= guest.dietary_notes.present? ? guest.dietary_notes : "---" %></td>
                <td class="px-6 py-3.5 text-gray-400 text-center"><%= guest.table_number || "---" %></td>
                <td class="px-6 py-3.5">
                  <div class="flex items-center gap-2">
                    <%= link_to "Edit", edit_client_event_guest_path(@event, guest), class: "text-xs text-gold-400 hover:text-gold-300" %>
                    <%= link_to "Delete", client_event_guest_path(@event, guest), data: { turbo_method: :delete, turbo_confirm: "Remove this guest?" }, class: "text-xs text-red-400 hover:text-red-300" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="w-12 h-12 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
        <p class="text-gray-500">No guests yet</p>
        <%= link_to "Add your first guest", new_client_event_guest_path(@event), class: "text-gold-400 hover:text-gold-300 text-sm mt-2 inline-block" %>
      </div>
    <% end %>
  </div>

  <%= render "components/pagination", pagy: @pagy %>
</div>
