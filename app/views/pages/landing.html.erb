<!-- HOW IT WORKS — 3 steps -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 to-surface-900"></div>
  <div class="max-w-5xl mx-auto px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 reveal">
      <p class="text-sm font-semibold text-gold-400 uppercase tracking-widest mb-3">Getting Started</p>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white">Up and running in 60 seconds</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 stagger">
      <% [
        { step: "01", title: "Create your account", desc: "Sign up free, name your organization. No credit card, no trial limits." },
        { step: "02", title: "Add your first event", desc: "Set date, venue, and budget. Invite clients and vendors to their portals." },
        { step: "03", title: "Manage everything", desc: "Tasks, vendors, budgets, guests, timelines — all in one place." },
      ].each do |step| %>
        <div class="text-center group">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-gold-500/20 to-gold-500/5 border border-gold-500/30 flex items-center justify-center mx-auto mb-5 group-hover:border-gold-400 group-hover:shadow-lg group-hover:shadow-gold-500/20 transition-all duration-300">
            <span class="text-xl font-black gold-text"><%= step[:step] %></span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2"><%= step[:title] %></h3>
          <p class="text-sm text-gray-400 leading-relaxed"><%= step[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

