      <h2 class="text-4xl sm:text-5xl font-extrabold text-white">Loved by planners worldwide</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
      <% [
        { text: "This replaced 4 different tools. The client portal alone saved us hours of back-and-forth emails every week.", name: "Sofia Rivera", role: "Founder, Rivera Events", initials: "SR", gradient: "from-gold-500 to-gold-700" },
        { text: "Budget tracking is a game changer. We caught a $12K overage before it happened. The UI is absolutely gorgeous.", name: "Daniel Kim", role: "Lead Planner, Elevate Co.", initials: "DK", gradient: "from-blue-500 to-blue-700" },
        { text: "My vendors love their portal. They can see exactly what's expected and when. It makes us look incredibly professional.", name: "Aisha Thompson", role: "Director, Moments by Aisha", initials: "AT", gradient: "from-emerald-500 to-emerald-700" },
      ].each do |t| %>
