<%# locals: (pagy:) %>
<% if pagy.pages > 1 %>
  <nav class="flex items-center justify-between px-1 py-4" aria-label="Pagination">
    <p class="text-xs text-gray-500">
      Showing <span class="font-medium text-gray-300"><%= pagy.from %></span> to <span class="font-medium text-gray-300"><%= pagy.to %></span> of <span class="font-medium text-gray-300"><%= pagy.count %></span>
    </p>
    <div class="flex items-center gap-1">
      <% if pagy.prev %>
        <%= link_to pagy_url_for(pagy, pagy.prev), class: "px-3 py-1.5 rounded-lg text-xs text-gray-400 hover:text-white hover:bg-white/[0.06] transition-all" do %>
          &larr; Prev
        <% end %>
      <% end %>
      <% pagy.series.each do |item| %>
        <% if item.is_a?(Integer) %>
          <%= link_to item, pagy_url_for(pagy, item), class: "px-3 py-1.5 rounded-lg text-xs text-gray-400 hover:text-white hover:bg-white/[0.06] transition-all" %>
        <% elsif item.is_a?(String) %>
          <span class="px-3 py-1.5 rounded-lg text-xs font-medium text-gold-400 bg-gold-500/10"><%= item %></span>
        <% elsif item == :gap %>
          <span class="px-2 text-gray-600">&hellip;</span>
        <% end %>
      <% end %>
      <% if pagy.next %>
        <%= link_to pagy_url_for(pagy, pagy.next), class: "px-3 py-1.5 rounded-lg text-xs text-gray-400 hover:text-white hover:bg-white/[0.06] transition-all" do %>
          Next &rarr;
        <% end %>
      <% end %>
    </div>
  </nav>
<% end %>
