<%# locals: (title:) %>
<div data-modal-target="dialog" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     data-action="click->modal#closeOnBackdrop">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-lg glass-card z-10">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-white"><%= title %></h3>
      <button data-action="modal#close" class="text-gray-400 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <%= yield %>
  </div>
</div>
