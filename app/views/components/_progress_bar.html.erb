<%# locals: (percentage:, label: nil, color: "gold") %>
<div>
  <% if label %>
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-sm text-gray-400"><%= label %></span>
      <span class="text-sm font-medium text-white"><%= percentage %>%</span>
    </div>
  <% end %>
  <div class="w-full h-2 rounded-full bg-white/5 overflow-hidden">
    <div class="h-full rounded-full transition-all duration-500"
         style="width: <%= [percentage, 100].min %>%; background: linear-gradient(to right, <%= theme_color(color, :from) %>, <%= theme_color(color, :to) %>)"></div>
  </div>
</div>
