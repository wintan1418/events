<% content_for(:page_title) { @vendor.name } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @vendor.name %></h1>
      <p class="text-gray-400 mt-1 capitalize"><%= @vendor.category.humanize %></p>
    </div>
    <%= link_to "Back", planner_vendors_path, class: "text-sm text-gray-400 hover:text-white" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Contact Details -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
      <h3 class="text-lg font-semibold text-white mb-4">Contact Information</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Email</dt>
          <dd class="text-sm text-white"><%= @vendor.email || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Phone</dt>
          <dd class="text-sm text-white"><%= @vendor.phone || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Website</dt>
          <dd class="text-sm">
            <% if @vendor.website.present? %>
              <%= link_to @vendor.website, @vendor.website, target: "_blank", rel: "noopener", class: "text-gold-400 hover:text-gold-300" %>
            <% else %>
              <span class="text-white">—</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm text-gray-400 mb-1">Address</dt>
          <dd class="text-sm text-white"><%= @vendor.address.present? ? @vendor.address : "—" %></dd>
        </div>
      </dl>
    </div>

    <!-- Notes -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
      <h3 class="text-lg font-semibold text-white mb-4">Notes</h3>
      <p class="text-sm text-gray-400"><%= @vendor.notes.present? ? @vendor.notes : "No notes available" %></p>
    </div>
  </div>

  <!-- Events Using This Vendor -->
  <% if @vendor.event_vendors.any? %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
      <h3 class="text-lg font-semibold text-white mb-4">Event History</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Event</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Amount</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="">
            <% @vendor.event_vendors.includes(:event).each do |ev| %>
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-4 py-3 text-white"><%= ev.event.title %></td>
                <td class="px-4 py-3 text-gray-400"><%= ev.event.event_date&.strftime("%b %d, %Y") || "TBD" %></td>
                <td class="px-4 py-3 text-gray-400 text-right"><%= number_to_currency(ev.contracted_amount) %></td>
                <td class="px-4 py-3"><%= render "components/badge", status: ev.status %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
