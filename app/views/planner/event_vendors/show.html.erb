<% content_for(:page_title) { "#{@event_vendor.vendor.name} - #{@event.title}" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @event_vendor.vendor.name %></h1>
      <p class="text-gray-400 mt-1"><%= @event.title %> &middot; <%= @event_vendor.vendor.category.humanize %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Back", planner_event_event_vendors_path(@event), class: "text-sm text-gray-400 hover:text-white" %>
      <%= link_to "Edit", edit_planner_event_event_vendor_path(@event, @event_vendor), class: "px-4 py-2 rounded-lg glass text-sm text-gray-300 hover:bg-white/10 transition-all" %>
      <%= render "components/badge", status: @event_vendor.status %>
    </div>
  </div>

  <!-- Payment Overview -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= render "components/stat_card", label: "Contracted", value: number_to_currency(@event_vendor.contracted_amount) %>
    <%= render "components/stat_card", label: "Paid", value: number_to_currency(@event_vendor.paid_amount), color: "emerald" %>
    <%= render "components/stat_card", label: "Balance Due", value: number_to_currency(@event_vendor.balance_due), color: "amber" %>
  </div>

  <!-- Payment Progress -->
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
    <h3 class="text-lg font-semibold text-white mb-4">Payment Progress</h3>
    <%= render "components/progress_bar", percentage: @event_vendor.payment_percentage, label: "#{number_to_currency(@event_vendor.paid_amount)} of #{number_to_currency(@event_vendor.contracted_amount)}", color: "emerald" %>
  </div>

  <!-- Details -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
      <h3 class="text-lg font-semibold text-white mb-4">Vendor Details</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Name</dt>
          <dd class="text-sm text-white"><%= @event_vendor.vendor.name %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Category</dt>
          <dd class="text-sm text-white capitalize"><%= @event_vendor.vendor.category.humanize %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Email</dt>
          <dd class="text-sm text-white"><%= @event_vendor.vendor.email || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Phone</dt>
          <dd class="text-sm text-white"><%= @event_vendor.vendor.phone || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Service Date</dt>
          <dd class="text-sm text-white"><%= @event_vendor.service_date&.strftime("%B %d, %Y") || "TBD" %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
      <h3 class="text-lg font-semibold text-white mb-4">Notes</h3>
      <p class="text-sm text-gray-400"><%= @event_vendor.notes.present? ? @event_vendor.notes : "No notes" %></p>
    </div>
  </div>

  <!-- Related Line Items -->
  <% if @event_vendor.line_items.any? %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
      <h3 class="text-lg font-semibold text-white mb-4">Related Budget Items</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Description</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Estimated</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Actual</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-center">Paid</th>
            </tr>
          </thead>
          <tbody class="">
            <% @event_vendor.line_items.each do |item| %>
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-4 py-3 text-white"><%= item.description %></td>
                <td class="px-4 py-3 text-gray-400 text-right"><%= number_to_currency(item.estimated_cost) %></td>
                <td class="px-4 py-3 text-gray-400 text-right"><%= number_to_currency(item.actual_cost) %></td>
                <td class="px-4 py-3 text-center">
                  <% if item.paid? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 ring-1 ring-inset ring-emerald-500/20">Paid</span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 ring-1 ring-inset ring-amber-500/20">Unpaid</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= link_to "Edit Assignment", edit_planner_event_event_vendor_path(@event, @event_vendor), class: "px-4 py-2 rounded-lg bg-gradient-to-r from-gold-500 to-gold-600 text-white text-sm font-medium hover:from-gold-400 hover:to-gold-500 transition-all" %>
    <%= link_to "Remove Vendor", planner_event_event_vendor_path(@event, @event_vendor), data: { turbo_method: :delete, turbo_confirm: "Remove this vendor from the event?" }, class: "px-4 py-2 rounded-lg glass text-sm text-red-400 hover:bg-red-500/10 transition-all" %>
  </div>
</div>
