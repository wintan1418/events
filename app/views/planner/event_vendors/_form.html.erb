<%= form_with(model: [:planner, @event, event_vendor], class: "space-y-6") do |f| %>
  <% if event_vendor.errors.any? %>
    <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20">
      <h3 class="text-sm font-medium text-red-400"><%= pluralize(event_vendor.errors.count, "error") %> prevented saving:</h3>
      <ul class="mt-2 text-sm text-red-300 list-disc list-inside">
        <% event_vendor.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 space-y-5">
    <div>
      <%= f.label :vendor_id, "Vendor", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.collection_select :vendor_id, Vendor.active.order(:name), :id, :name, { include_blank: "Select a vendor" }, class: "w-full rounded-xl bg-[#111827] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :contracted_amount, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.number_field :contracted_amount, step: 0.01, min: 0, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "0.00" %>
      </div>
      <div>
        <%= f.label :paid_amount, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.number_field :paid_amount, step: 0.01, min: 0, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "0.00" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.select :status, EventVendor.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "w-full rounded-xl bg-[#111827] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all" %>
      </div>
      <div>
        <%= f.label :service_date, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.date_field :service_date, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all" %>
      </div>
    </div>

    <div>
      <%= f.label :notes, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.text_area :notes, rows: 3, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "Notes about this vendor assignment" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "px-6 py-2.5 rounded-xl bg-gradient-to-r from-gold-500 to-gold-600 text-black font-semibold hover:from-gold-400 hover:to-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:ring-offset-2 focus:ring-offset-surface-950 transition-all cursor-pointer text-sm" %>
    <%= link_to "Cancel", planner_event_event_vendors_path(@event), class: "px-6 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.08] text-gray-300 hover:text-white hover:border-white/[0.12] transition-all text-sm" %>
  </div>
<% end %>
