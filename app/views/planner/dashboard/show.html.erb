<% content_for(:page_title) { "Dashboard" } %>

<div class="space-y-8">
  <!-- Welcome Header -->
  <div class="relative overflow-hidden rounded-2xl border border-white/[0.06] bg-gradient-to-r from-gold-500/10 via-white/[0.03] to-transparent p-8">
    <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/5 rounded-full -translate-y-32 translate-x-32"></div>
    <div class="absolute bottom-0 right-20 w-32 h-32 bg-gold-400/5 rounded-full translate-y-16"></div>
    <div class="relative">
      <p class="text-sm text-gold-400 font-medium">Welcome back</p>
      <h1 class="text-3xl font-bold text-white mt-1"><%= current_user.first_name %> <span class="text-gray-500 font-normal text-lg">/ Planner</span></h1>
      <p class="text-gray-400 mt-2 text-sm">Here's what's happening with your events today.</p>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <%= render "components/stat_card", label: "Upcoming Events", value: @upcoming_count,
        icon_path: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" %>
    <%= render "components/stat_card", label: "Total Events", value: @total_events,
        icon_path: "M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z", color: "blue" %>
    <%= render "components/stat_card", label: "Tasks Due Soon", value: @tasks_due.count,
        icon_path: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z", color: "amber" %>
    <%= render "components/stat_card", label: "Overdue Tasks", value: @overdue_tasks.count,
        icon_path: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z", color: "red" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Upcoming Events (2/3 width) -->
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
        <div class="flex items-center justify-between p-6 pb-0">
          <div>
            <h3 class="text-lg font-semibold text-white">Upcoming Events</h3>
            <p class="text-xs text-gray-500 mt-1">Your next scheduled events</p>
          </div>
          <%= link_to planner_events_path, class: "flex items-center gap-1.5 text-sm text-gold-400 hover:text-gold-300 transition-colors" do %>
            <span>View All</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <% end %>
        </div>

        <div class="p-6">
          <% if @my_events.any? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <% @my_events.each do |event| %>
                <%= link_to planner_event_path(event), class: "block rounded-xl border border-white/[0.06] bg-white/[0.03] p-5 hover:border-gold-500/20 hover:bg-white/[0.06] transition-all duration-300 group" do %>
                  <div class="flex items-start justify-between mb-3">
                    <div class="flex items-center gap-2">
                      <% dot_cls = case event.status; when 'confirmed' then 'bg-emerald-400'; when 'planning' then 'bg-blue-400'; when 'in_progress' then 'bg-amber-400'; else 'bg-gray-400'; end %>
                      <div class="w-2 h-2 rounded-full <%= dot_cls %>"></div>
                      <h4 class="font-semibold text-white group-hover:text-gold-400 transition-colors text-sm"><%= event.title %></h4>
                    </div>
                    <%= render "components/badge", status: event.status %>
                  </div>

                  <div class="space-y-2">
                    <div class="flex items-center gap-2 text-xs text-gray-500">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                      <span><%= event.venue || "Venue TBD" %></span>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-500">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                      <span><%= event.event_date&.strftime("%b %d, %Y") || "Date TBD" %></span>
                      <% if event.days_until && event.days_until > 0 %>
                        <span class="text-gold-400/70">&middot; <%= event.days_until %> days away</span>
                      <% end %>
                    </div>
                    <% if event.client %>
                      <div class="flex items-center gap-2 text-xs text-gray-500">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                        <span><%= event.client.full_name %></span>
                      </div>
                    <% end %>
                  </div>

                  <% if event.tasks.any? %>
                    <div class="mt-4 pt-3 border-t border-white/[0.04]">
                      <%= render "components/progress_bar", percentage: event.tasks_completion_percentage, label: "Tasks", color: "emerald" %>
                    </div>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <%= render "components/empty_state", icon_path: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5", title: "No upcoming events", message: "Create your first event to get started.", action_path: new_planner_event_path, action_label: "Create Event" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Tasks Panel (1/3 width) -->
    <div class="space-y-6">
      <!-- Overdue Tasks -->
      <% if @overdue_tasks.any? %>
        <div class="rounded-2xl border border-red-500/20 bg-red-500/[0.03] backdrop-blur-sm overflow-hidden">
          <div class="px-5 py-4 border-b border-red-500/10">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-red-400 animate-pulse"></div>
              <h3 class="text-sm font-semibold text-red-400">Overdue Tasks</h3>
              <span class="ml-auto text-xs text-red-400/60 bg-red-500/10 px-2 py-0.5 rounded-full"><%= @overdue_tasks.count %></span>
            </div>
          </div>
          <div class="p-3 space-y-1 max-h-64 overflow-y-auto">
            <% @overdue_tasks.limit(5).each do |task| %>
              <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-red-500/5 transition-colors">
                <div class="w-1.5 h-1.5 rounded-full bg-red-400 flex-shrink-0"></div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm text-white truncate"><%= task.title %></p>
                  <p class="text-[11px] text-gray-500"><%= task.event.title %> &middot; Due <%= task.due_date&.strftime("%b %d") %></p>
                </div>
                <%= render "components/badge", status: task.priority %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- My Tasks -->
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-white/[0.06]">
          <h3 class="text-sm font-semibold text-white">Active Tasks</h3>
          <p class="text-[11px] text-gray-500 mt-0.5"><%= @completed_tasks %>/<%= @total_tasks %> completed</p>
        </div>
        <div class="p-3 space-y-1 max-h-80 overflow-y-auto">
          <% if @recent_tasks.any? %>
            <% @recent_tasks.each do |task| %>
              <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/[0.04] transition-colors group">
                <div class="w-4 h-4 rounded border border-white/20 flex items-center justify-center flex-shrink-0 group-hover:border-gold-500/40">
                  <% if task.in_progress? %>
                    <div class="w-2 h-2 rounded-sm bg-blue-400"></div>
                  <% end %>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm text-white truncate"><%= task.title %></p>
                  <p class="text-[11px] text-gray-500"><%= task.event.title %></p>
                </div>
                <% if task.due_date %>
                  <span class="text-[10px] text-gray-600 flex-shrink-0"><%= task.due_date.strftime("%b %d") %></span>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8">
              <p class="text-sm text-gray-500">All caught up!</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
