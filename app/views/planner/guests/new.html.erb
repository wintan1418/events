<% content_for(:page_title) { "Add Guest - #{@event.title}" } %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <%= link_to planner_event_guests_path(@event), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
      &larr; Back to Guest List
    <% end %>
    <h1 class="text-2xl font-bold text-white mt-2">Add Guest</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @event.title %></p>
  </div>
  <%= render "form", guest: @guest %>
</div>
