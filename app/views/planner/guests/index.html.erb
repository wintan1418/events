<% content_for(:page_title) { "Guest List - #{@event.title}" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to planner_event_path(@event), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
        &larr; <%= @event.title %>
      <% end %>
      <h1 class="text-2xl font-bold text-white mt-1">Guest List</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= @guests.size %> guests</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to export_planner_event_guests_path(@event, format: :csv), class: "flex items-center gap-2 px-4 py-2 rounded-xl bg-white/[0.04] border border-white/[0.08] text-sm text-gray-300 hover:text-white hover:border-white/[0.12] transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        Export
      <% end %>
      <%= link_to new_planner_event_guest_path(@event), class: "flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-gold-500 to-gold-600 text-black text-sm font-semibold hover:from-gold-400 hover:to-gold-500 transition-all shadow-lg shadow-gold-500/20" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Add Guest
      <% end %>
    </div>
  </div>

  <!-- RSVP Summary -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <%= render "components/stat_card", label: "Total Guests", value: @guests.size,
        icon_path: "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" %>
    <%= render "components/stat_card", label: "Confirmed", value: @guests.select(&:confirmed?).size, color: "emerald",
        icon_path: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" %>
    <%= render "components/stat_card", label: "Pending", value: @guests.select(&:pending?).size, color: "amber",
        icon_path: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" %>
    <%= render "components/stat_card", label: "Declined", value: @guests.select(&:declined?).size, color: "red",
        icon_path: "M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" %>
  </div>

  <!-- Guest Table -->
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
    <% if @guests.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">RSVP</th>
              <th class="px-6 py-3.5 text-center text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Party</th>
              <th class="px-6 py-3.5 text-center text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Table</th>
              <th class="px-6 py-3.5 text-right text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @guests.each do |guest| %>
              <tr class="border-b border-white/[0.03] hover:bg-white/[0.02] transition-colors group">
                <td class="px-6 py-3.5">
                  <%= link_to planner_event_guest_path(@event, guest), class: "flex items-center gap-3" do %>
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0">
                      <%= guest.first_name&.first %><%= guest.last_name&.first %>
                    </div>
                    <span class="font-medium text-white group-hover:text-gold-400 transition-colors"><%= guest.full_name %></span>
                  <% end %>
                </td>
                <td class="px-6 py-3.5 text-gray-400 text-xs"><%= guest.email || "---" %></td>
                <td class="px-6 py-3.5"><%= render "components/badge", status: guest.rsvp_status %></td>
                <td class="px-6 py-3.5 text-gray-400 text-center"><%= guest.party_size %></td>
                <td class="px-6 py-3.5 text-gray-400 text-center"><%= guest.table_number || "---" %></td>
                <td class="px-6 py-3.5 text-right">
                  <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                    <%= link_to edit_planner_event_guest_path(@event, guest), class: "text-xs text-gray-400 hover:text-gold-400 transition-colors" do %>
                      Edit
                    <% end %>
                    <%= link_to planner_event_guest_path(@event, guest), data: { turbo_method: :delete, turbo_confirm: "Remove this guest?" }, class: "text-xs text-gray-400 hover:text-red-400 transition-colors" do %>
                      Remove
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-16 px-8">
        <div class="w-14 h-14 rounded-2xl bg-gold-500/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
        </div>
        <h3 class="text-white font-medium">No guests yet</h3>
        <p class="text-gray-500 text-sm mt-1">Start building your guest list.</p>
        <%= link_to new_planner_event_guest_path(@event), class: "inline-flex items-center gap-2 mt-4 text-sm text-gold-400 hover:text-gold-300 transition-colors" do %>
          Add your first guest &rarr;
        <% end %>
      </div>
    <% end %>
  </div>

  <%= render "components/pagination", pagy: @pagy %>
</div>
