<%= form_with(model: [:planner, @event, guest], class: "space-y-6") do |f| %>
  <% if guest.errors.any? %>
    <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20">
      <h3 class="text-sm font-medium text-red-400"><%= pluralize(guest.errors.count, "error") %> prevented saving:</h3>
      <ul class="mt-2 text-sm text-red-300 list-disc list-inside">
        <% guest.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :first_name, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.text_field :first_name, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "First name" %>
      </div>
      <div>
        <%= f.label :last_name, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.text_field :last_name, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "Last name" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.email_field :email, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "email@example.com" %>
      </div>
      <div>
        <%= f.label :phone, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.phone_field :phone, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "Phone number" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      <div>
        <%= f.label :rsvp_status, "RSVP Status", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.select :rsvp_status, Guest.rsvp_statuses.keys.map { |k| [k.humanize, k] }, {}, class: "w-full rounded-xl bg-[#111827] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all" %>
      </div>
      <div>
        <%= f.label :party_size, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.number_field :party_size, min: 1, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "1" %>
      </div>
      <div>
        <%= f.label :table_number, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <%= f.number_field :table_number, min: 1, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "Table number" %>
      </div>
    </div>

    <div>
      <%= f.label :meal_choice, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.text_field :meal_choice, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "e.g. Chicken, Fish, Vegetarian" %>
    </div>

    <div>
      <%= f.label :dietary_notes, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.text_area :dietary_notes, rows: 2, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "Allergies, dietary restrictions, etc." %>
    </div>

    <div>
      <%= f.label :notes, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
      <%= f.text_area :notes, rows: 2, class: "w-full rounded-xl bg-white/[0.04] border border-white/[0.08] px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40 focus:border-gold-500/30 transition-all", placeholder: "Additional notes" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "px-6 py-2.5 rounded-xl bg-gradient-to-r from-gold-500 to-gold-600 text-black font-semibold hover:from-gold-400 hover:to-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:ring-offset-2 focus:ring-offset-surface-950 transition-all cursor-pointer text-sm" %>
    <%= link_to "Cancel", planner_event_guests_path(@event), class: "px-6 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.08] text-gray-300 hover:text-white hover:border-white/[0.12] transition-all text-sm" %>
  </div>
<% end %>
