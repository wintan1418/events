<% content_for(:page_title) { "Edit Task - #{@task.title}" } %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <%= link_to planner_event_tasks_path(@event), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
      &larr; Back to Tasks
    <% end %>
    <h1 class="text-2xl font-bold text-white mt-2">Edit Task</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @event.title %></p>
  </div>
  <%= render "form", task: @task %>
</div>
