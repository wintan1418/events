<% content_for(:page_title) { "Tasks - #{@event.title}" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to planner_event_path(@event), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
        &larr; <%= @event.title %>
      <% end %>
      <h1 class="text-2xl font-bold text-white mt-1">Tasks</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= @tasks.count %> total &middot; <%= @tasks.select(&:completed?).size %> done</p>
    </div>
    <%= link_to new_planner_event_task_path(@event), class: "flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-gold-500 to-gold-600 text-black text-sm font-semibold hover:from-gold-400 hover:to-gold-500 transition-all shadow-lg shadow-gold-500/20" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      New Task
    <% end %>
  </div>

  <!-- Progress bar -->
  <% completion = @tasks.any? ? (@tasks.select(&:completed?).size.to_f / @tasks.size * 100).round : 0 %>
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-5">
    <%= render "components/progress_bar", percentage: completion, label: "Overall Progress", color: "emerald" %>
  </div>

  <!-- Kanban Board -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <% { pending: "To Do", in_progress: "In Progress", completed: "Done" }.each do |status_key, status_label| %>
      <% column_tasks = @tasks.select { |t| t.status == status_key.to_s } %>
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.06]">
          <div class="flex items-center gap-2">
            <% kanban_dot = case status_key; when :pending then 'bg-gray-400'; when :in_progress then 'bg-blue-400'; else 'bg-emerald-400'; end %>
            <div class="w-2 h-2 rounded-full <%= kanban_dot %>"></div>
            <h3 class="text-sm font-semibold text-white"><%= status_label %></h3>
          </div>
          <span class="text-xs text-gray-500 bg-white/[0.04] px-2 py-0.5 rounded-full"><%= column_tasks.size %></span>
        </div>

        <div class="p-3 space-y-2 min-h-[200px]">
          <% column_tasks.each do |task| %>
            <div class="rounded-xl border border-white/[0.06] bg-white/[0.03] p-4 hover:border-gold-500/20 hover:bg-white/[0.06] transition-all duration-200 group">
              <div class="flex items-start justify-between mb-2">
                <%= link_to edit_planner_event_task_path(@event, task), class: "font-medium text-sm text-white group-hover:text-gold-400 transition-colors" do %>
                  <%= task.title %>
                <% end %>
                <%= render "components/badge", status: task.priority %>
              </div>

              <% if task.due_date %>
                <p class="text-xs flex items-center gap-1.5 mb-2 <%= task.due_date < Date.current && !task.completed? ? 'text-red-400' : 'text-gray-500' %>">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <%= task.due_date.strftime("%b %d") %>
                  <% if task.due_date < Date.current && !task.completed? %>
                    <span class="text-red-400/70">(overdue)</span>
                  <% end %>
                </p>
              <% end %>

              <% if task.assigned_to %>
                <div class="flex items-center gap-2 mt-3 pt-3 border-t border-white/[0.04]">
                  <div class="w-5 h-5 rounded-md bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                    <span class="text-[9px] text-white font-bold"><%= task.assigned_to.initials %></span>
                  </div>
                  <span class="text-[11px] text-gray-500"><%= task.assigned_to.full_name %></span>
                </div>
              <% end %>

              <div class="flex items-center gap-3 mt-3 pt-2">
                <%= link_to edit_planner_event_task_path(@event, task), class: "text-[11px] text-gray-500 hover:text-gold-400 transition-colors" do %>
                  Edit
                <% end %>
                <%= link_to planner_event_task_path(@event, task), data: { turbo_method: :delete, turbo_confirm: "Delete this task?" }, class: "text-[11px] text-gray-500 hover:text-red-400 transition-colors" do %>
                  Delete
                <% end %>
              </div>
            </div>
          <% end %>

          <% if column_tasks.empty? %>
            <div class="text-center py-8">
              <p class="text-xs text-gray-600">No tasks</p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
