<% content_for(:page_title) { "New Event" } %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <%= link_to planner_events_path, class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
      &larr; Back to Events
    <% end %>
    <h1 class="text-2xl font-bold text-white mt-2">Create New Event</h1>
    <p class="text-sm text-gray-500 mt-1">Fill in the details to get your event started.</p>
  </div>
  <%= render "form", event: @event %>
</div>
