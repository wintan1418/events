<% content_for(:page_title) { "Edit #{@event.title}" } %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <%= link_to planner_event_path(@event), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
      &larr; Back to <%= @event.title %>
    <% end %>
    <h1 class="text-2xl font-bold text-white mt-2">Edit Event</h1>
    <p class="text-sm text-gray-500 mt-1">Update your event details.</p>
  </div>
  <%= render "form", event: @event %>
</div>
