<% content_for(:page_title) { @event.title } %>

<% vendor = current_user.vendor_profile %>
<% event_vendor = @event.event_vendors.find_by(vendor: vendor) %>

<div class="space-y-8">
  <!-- Header -->
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @event.title %></h1>
      <p class="text-gray-400 mt-1">
        <%= @event.venue || "Venue TBD" %> &middot; <%= @event.event_date&.strftime("%B %d, %Y") || "Date TBD" %>
      </p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "All Events", vendor_portal_events_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
      <%= render "components/badge", status: @event.status %>
    </div>
  </div>

  <!-- Event Info -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 glass-card">
      <h3 class="text-lg font-semibold text-white mb-4">Event Details</h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <dt class="text-sm text-gray-400">Event Type</dt>
          <dd class="text-sm text-white mt-0.5 capitalize"><%= @event.event_type.humanize %></dd>
        </div>
        <div>
          <dt class="text-sm text-gray-400">Date</dt>
          <dd class="text-sm text-white mt-0.5"><%= @event.event_date&.strftime("%B %d, %Y") || "TBD" %></dd>
        </div>
        <div>
          <dt class="text-sm text-gray-400">Time</dt>
          <dd class="text-sm text-white mt-0.5">
            <% if @event.start_time %>
              <%= @event.start_time.strftime("%l:%M %p").strip %>
              <% if @event.end_time %>
                &ndash; <%= @event.end_time.strftime("%l:%M %p").strip %>
              <% end %>
            <% else %>
              TBD
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm text-gray-400">Venue</dt>
          <dd class="text-sm text-white mt-0.5"><%= @event.venue || "TBD" %></dd>
        </div>
        <% if @event.venue_address.present? %>
          <div class="sm:col-span-2">
            <dt class="text-sm text-gray-400">Venue Address</dt>
            <dd class="text-sm text-white mt-0.5"><%= @event.venue_address %></dd>
          </div>
        <% end %>
        <% if @event.description.present? %>
          <div class="sm:col-span-2">
            <dt class="text-sm text-gray-400">Description</dt>
            <dd class="text-sm text-gray-300 mt-0.5 leading-relaxed"><%= simple_format(@event.description) %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Days Until Card -->
    <div class="space-y-4">
      <% if @event.days_until && @event.days_until >= 0 %>
        <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 text-center">
          <p class="text-4xl font-bold gold-text"><%= @event.days_until %></p>
          <p class="text-sm text-gray-400 mt-1">Days Until Event</p>
        </div>
      <% elsif @event.days_until && @event.days_until < 0 %>
        <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 text-center">
          <p class="text-lg font-semibold text-gray-400">Event Completed</p>
          <p class="text-sm text-gray-500 mt-1"><%= @event.days_until.abs %> days ago</p>
        </div>
      <% end %>

      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 text-center">
        <p class="text-sm text-gray-400">Estimated Guests</p>
        <p class="text-2xl font-bold text-white mt-1"><%= @event.estimated_guests %></p>
      </div>
    </div>
  </div>

  <!-- Contract Summary -->
  <% if event_vendor %>
    <div>
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-white">Your Contract</h3>
        <%= link_to vendor_portal_event_event_vendor_path(@event, event_vendor), class: "text-sm text-gold-400 hover:text-gold-300 transition-colors" do %>
          View Full Details &rarr;
        <% end %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <%= render "components/stat_card", label: "Contracted", value: number_to_currency(event_vendor.contracted_amount),
            icon_path: "M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" %>
        <%= render "components/stat_card", label: "Paid", value: number_to_currency(event_vendor.paid_amount),
            icon_path: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z", color: "emerald" %>
        <%= render "components/stat_card", label: "Balance Due", value: number_to_currency(event_vendor.balance_due),
            icon_path: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z", color: "amber" %>
        <%= render "components/stat_card", label: "Status", value: event_vendor.status.humanize,
            icon_path: "M9 12.75L11.25 15 15 9.75m-7.5-3.75h13.5A2.25 2.25 0 0121 8.25v7.5a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15.75v-7.5A2.25 2.25 0 015.25 6z", color: "blue" %>
      </div>

      <!-- Payment Progress -->
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 mt-4">
        <h3 class="text-sm font-semibold text-white mb-3">Payment Progress</h3>
        <%= render "components/progress_bar", percentage: event_vendor.payment_percentage, label: "#{number_to_currency(event_vendor.paid_amount)} of #{number_to_currency(event_vendor.contracted_amount)}", color: "emerald" %>
      </div>

      <!-- Contract Quick Info -->
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6 mt-4">
        <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <dt class="text-sm text-gray-400">Service Date</dt>
            <dd class="text-sm text-white mt-0.5"><%= event_vendor.service_date&.strftime("%B %d, %Y") || "TBD" %></dd>
          </div>
          <div>
            <dt class="text-sm text-gray-400">Contract Status</dt>
            <dd class="mt-0.5"><%= render "components/badge", status: event_vendor.status %></dd>
          </div>
          <div>
            <dt class="text-sm text-gray-400">Payment</dt>
            <dd class="text-sm text-white mt-0.5"><%= event_vendor.payment_percentage %>% complete</dd>
          </div>
        </dl>
      </div>
    </div>
  <% end %>

  <!-- Day-of Timeline -->
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
    <h3 class="text-lg font-semibold text-white mb-6">Day-of Schedule</h3>

    <% timelines = @event.timelines.ordered %>
    <% if timelines.any? %>
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-8 top-0 bottom-0 w-px bg-white/10"></div>

        <div class="space-y-4">
          <% timelines.each do |timeline| %>
            <div class="relative flex gap-6">
              <!-- Time -->
              <div class="flex-shrink-0 w-16 text-right pt-1">
                <p class="text-sm font-semibold text-gold-400"><%= timeline.start_time&.strftime("%l:%M %p")&.strip %></p>
                <% if timeline.end_time %>
                  <p class="text-xs text-gray-500"><%= timeline.end_time.strftime("%l:%M %p").strip %></p>
                <% end %>
              </div>

              <!-- Dot on the line -->
              <div class="flex-shrink-0 w-3 h-3 mt-2 rounded-full bg-gold-500 ring-4 ring-gold-500/20 relative z-10"></div>

              <!-- Content -->
              <div class="flex-1 glass rounded-lg px-4 py-3">
                <h4 class="font-medium text-white text-sm"><%= timeline.title %></h4>
                <% if timeline.description.present? %>
                  <p class="text-xs text-gray-400 mt-1"><%= timeline.description %></p>
                <% end %>
                <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                  <% if timeline.responsible_party.present? %>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                      </svg>
                      <%= timeline.responsible_party %>
                    </span>
                  <% end %>
                  <% if timeline.location.present? %>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                      </svg>
                      <%= timeline.location %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-6">No schedule entries for this event yet.</p>
    <% end %>
  </div>
</div>
