<% content_for(:page_title) { "My Events" } %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">My Events</h1>
      <p class="text-gray-400 mt-1">Events you are contracted for</p>
    </div>
    <%= link_to vendor_portal_dashboard_path, class: "text-sm text-gray-400 hover:text-white transition-colors" do %>
      Back to Dashboard
    <% end %>
  </div>

  <!-- Events Table -->
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
    <% if @events.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Event</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Venue</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Contracted</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Paid</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="">
            <% @events.each do |event| %>
              <% event_vendor = event.event_vendors.find_by(vendor: current_user.vendor_profile) %>
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-3.5">
                  <%= link_to vendor_portal_event_path(event), class: "font-medium text-white hover:text-gold-400 transition-colors" do %>
                    <%= event.title %>
                  <% end %>
                  <p class="text-xs text-gray-500 mt-0.5"><%= event.event_type.humanize %></p>
                </td>
                <td class="px-6 py-3.5 text-gray-400"><%= event.event_date&.strftime("%b %d, %Y") || "TBD" %></td>
                <td class="px-6 py-3.5 text-gray-400"><%= event.venue || "—" %></td>
                <td class="px-6 py-3.5 text-gray-400 text-right"><%= number_to_currency(event_vendor&.contracted_amount) %></td>
                <td class="px-6 py-3.5 text-emerald-400 text-right"><%= number_to_currency(event_vendor&.paid_amount) %></td>
                <td class="px-6 py-3.5">
                  <% if event_vendor %>
                    <%= render "components/badge", status: event_vendor.status %>
                  <% else %>
                    <span class="text-gray-500">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="w-12 h-12 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
        </svg>
        <p class="text-gray-500">No events assigned yet</p>
        <p class="text-sm text-gray-600 mt-1">You will see events here once you are contracted for them.</p>
      </div>
    <% end %>
  </div>
</div>
