<% content_for(:page_title) { "Vendor Dashboard" } %>

<div class="space-y-8">
  <!-- Welcome Header -->
  <div class="relative overflow-hidden rounded-2xl border border-white/[0.06] bg-gradient-to-r from-gold-500/10 via-white/[0.03] to-transparent p-8">
    <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/5 rounded-full -translate-y-32 translate-x-32"></div>
    <div class="absolute bottom-0 right-20 w-32 h-32 bg-gold-400/5 rounded-full translate-y-16"></div>
    <div class="relative">
      <p class="text-sm text-gold-400 font-medium">Vendor Portal</p>
      <h1 class="text-3xl font-bold text-white mt-1">Welcome, <%= current_user.first_name %></h1>
      <p class="text-gray-400 mt-2 text-sm">Track your events, contracts, and payments in one place.</p>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <%= render "components/stat_card", label: "Active Events", value: @event_vendors.count,
        icon_path: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" %>
    <%= render "components/stat_card", label: "Total Contracted", value: number_to_currency(@total_contracted),
        icon_path: "M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z", color: "emerald" %>
    <%= render "components/stat_card", label: "Total Paid", value: number_to_currency(@total_paid),
        icon_path: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z", color: "blue" %>
    <%= render "components/stat_card", label: "Pending Payment", value: number_to_currency(@pending_payment),
        icon_path: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z", color: "amber" %>
  </div>

  <!-- Payment Progress -->
  <% if @total_contracted > 0 %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="text-lg font-semibold text-white">Payment Progress</h3>
          <p class="text-xs text-gray-500 mt-1">Overall payment status across all contracts</p>
        </div>
        <span class="text-sm font-medium text-gold-400"><%= (@total_paid.to_f / @total_contracted * 100).round(1) %>%</span>
      </div>
      <%= render "components/progress_bar", percentage: (@total_paid.to_f / @total_contracted * 100).round(1), color: "emerald" %>
    </div>
  <% end %>

  <!-- Assigned Events -->
  <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
    <div class="flex items-center justify-between p-6 pb-4">
      <div>
        <h3 class="text-lg font-semibold text-white">Assigned Events</h3>
        <p class="text-xs text-gray-500 mt-1">Events where you've been contracted</p>
      </div>
      <%= link_to vendor_portal_events_path, class: "flex items-center gap-1.5 text-sm text-gold-400 hover:text-gold-300 transition-colors" do %>
        <span>View All</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      <% end %>
    </div>

    <% if @event_vendors.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-y border-white/[0.06]">
              <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Event</th>
              <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Contracted</th>
              <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Paid</th>
              <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @event_vendors.each do |ev| %>
              <tr class="border-b border-white/[0.03] hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-4">
                  <p class="font-medium text-white"><%= ev.event.title %></p>
                  <p class="text-[11px] text-gray-500 mt-0.5"><%= ev.event.venue || "Venue TBD" %></p>
                </td>
                <td class="px-6 py-4 text-gray-400 text-xs"><%= ev.event.event_date&.strftime("%b %d, %Y") || "TBD" %></td>
                <td class="px-6 py-4 text-white font-medium"><%= number_to_currency(ev.contracted_amount) %></td>
                <td class="px-6 py-4">
                  <span class="text-emerald-400 font-medium"><%= number_to_currency(ev.paid_amount) %></span>
                  <% remaining = ev.contracted_amount.to_d - ev.paid_amount.to_d %>
                  <% if remaining > 0 %>
                    <span class="text-[10px] text-gray-600 ml-1">(<%= number_to_currency(remaining) %> due)</span>
                  <% end %>
                </td>
                <td class="px-6 py-4"><%= render "components/badge", status: ev.status %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <div class="w-14 h-14 rounded-2xl bg-gold-500/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        </div>
        <h3 class="text-white font-medium">No Events Yet</h3>
        <p class="text-gray-500 text-sm mt-1">You'll see your events here once a planner adds you.</p>
      </div>
    <% end %>
  </div>
</div>
