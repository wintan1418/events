<% content_for(:page_title) { @user.full_name } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center">
        <span class="text-lg font-medium text-gray-400"><%= @user.initials %></span>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-white"><%= @user.full_name %></h1>
        <p class="text-gray-400 mt-1"><%= @user.email %></p>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Back", admin_users_path, class: "text-sm text-gray-400 hover:text-white" %>
      <%= link_to "Edit", edit_admin_user_path(@user), class: "px-4 py-2 rounded-lg glass text-sm text-gray-300 hover:bg-white/10 transition-all" %>
      <%= render "components/badge", status: @user.role %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- User Details -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-4">User Details</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">First Name</dt>
          <dd class="text-sm text-white"><%= @user.first_name %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Last Name</dt>
          <dd class="text-sm text-white"><%= @user.last_name %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Role</dt>
          <dd class="text-sm text-white capitalize"><%= @user.role.humanize %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Phone</dt>
          <dd class="text-sm text-white"><%= @user.phone || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Status</dt>
          <dd class="text-sm">
            <% if @user.active? %>
              <span class="text-emerald-400">Active</span>
            <% else %>
              <span class="text-red-400">Inactive</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Sign In Activity -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Activity</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Sign In Count</dt>
          <dd class="text-sm text-white"><%= @user.sign_in_count %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Current Sign In</dt>
          <dd class="text-sm text-white"><%= @user.current_sign_in_at&.strftime("%b %d, %Y %l:%M %p") || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Last Sign In</dt>
          <dd class="text-sm text-white"><%= @user.last_sign_in_at&.strftime("%b %d, %Y %l:%M %p") || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Confirmed At</dt>
          <dd class="text-sm text-white"><%= @user.confirmed_at&.strftime("%b %d, %Y") || "Unconfirmed" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Member Since</dt>
          <dd class="text-sm text-white"><%= @user.created_at.strftime("%b %d, %Y") %></dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Related Events -->
  <% user_events = @user.planner? ? @user.planned_events : (@user.client? ? @user.client_events : Event.none) %>
  <% if user_events.any? %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-4"><%= @user.planner? ? "Planned Events" : "Client Events" %></h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Event</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="">
            <% user_events.each do |event| %>
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-3.5">
                  <%= link_to event.title, admin_event_path(event), class: "text-white hover:text-gold-400" %>
                </td>
                <td class="px-6 py-3.5 text-gray-400"><%= event.event_date&.strftime("%b %d, %Y") || "TBD" %></td>
                <td class="px-6 py-3.5"><%= render "components/badge", status: event.status %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= link_to "Edit User", edit_admin_user_path(@user), class: "px-4 py-2 rounded-lg bg-gradient-to-r from-gold-500 to-gold-600 text-white text-sm font-medium hover:from-gold-400 hover:to-gold-500 transition-all" %>
    <%= link_to "Delete User", admin_user_path(@user), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this user?" }, class: "px-4 py-2 rounded-lg glass text-sm text-red-400 hover:bg-red-500/10 transition-all" %>
  </div>
</div>
