<% content_for(:page_title) { @vendor.name } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @vendor.name %></h1>
      <p class="text-gray-400 mt-1 capitalize"><%= @vendor.category.humanize %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Back", admin_vendors_path, class: "text-sm text-gray-400 hover:text-white" %>
      <%= link_to "Edit", edit_admin_vendor_path(@vendor), class: "px-4 py-2 rounded-lg glass text-sm text-gray-300 hover:bg-white/10 transition-all" %>
      <% if @vendor.active? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 ring-1 ring-inset ring-emerald-500/20">Active</span>
      <% else %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-500/10 text-red-400 ring-1 ring-inset ring-red-500/20">Inactive</span>
      <% end %>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= render "components/stat_card", label: "Total Events", value: @vendor.event_vendors.count %>
    <%= render "components/stat_card", label: "Total Revenue", value: number_to_currency(@vendor.event_vendors.sum(:contracted_amount)), color: "emerald" %>
    <%= render "components/stat_card", label: "Total Paid", value: number_to_currency(@vendor.event_vendors.sum(:paid_amount)), color: "blue" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Contact Details -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Contact Information</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Email</dt>
          <dd class="text-sm text-white"><%= @vendor.email || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Phone</dt>
          <dd class="text-sm text-white"><%= @vendor.phone || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Website</dt>
          <dd class="text-sm">
            <% if @vendor.website.present? %>
              <%= link_to @vendor.website, @vendor.website, target: "_blank", rel: "noopener", class: "text-gold-400 hover:text-gold-300" %>
            <% else %>
              <span class="text-white">—</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm text-gray-400 mb-1">Address</dt>
          <dd class="text-sm text-white"><%= @vendor.address.present? ? @vendor.address : "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm text-gray-400">Linked User</dt>
          <dd class="text-sm text-white"><%= @vendor.user&.full_name || "None" %></dd>
        </div>
      </dl>
    </div>

    <!-- Notes -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Notes</h3>
      <p class="text-sm text-gray-400"><%= @vendor.notes.present? ? @vendor.notes : "No notes" %></p>
    </div>
  </div>

  <!-- Event History -->
  <% if @vendor.event_vendors.any? %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Event History</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Event</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Contracted</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider text-right">Paid</th>
              <th class="px-6 py-3.5 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="">
            <% @vendor.event_vendors.includes(:event).each do |ev| %>
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-3.5">
                  <%= link_to ev.event.title, admin_event_path(ev.event), class: "text-white hover:text-gold-400" %>
                </td>
                <td class="px-6 py-3.5 text-gray-400"><%= ev.event.event_date&.strftime("%b %d, %Y") || "TBD" %></td>
                <td class="px-6 py-3.5 text-gray-400 text-right"><%= number_to_currency(ev.contracted_amount) %></td>
                <td class="px-6 py-3.5 text-emerald-400 text-right"><%= number_to_currency(ev.paid_amount) %></td>
                <td class="px-6 py-3.5"><%= render "components/badge", status: ev.status %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= link_to "Edit Vendor", edit_admin_vendor_path(@vendor), class: "px-4 py-2 rounded-lg bg-gradient-to-r from-gold-500 to-gold-600 text-white text-sm font-medium hover:from-gold-400 hover:to-gold-500 transition-all" %>
    <%= link_to "Delete Vendor", admin_vendor_path(@vendor), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this vendor?" }, class: "px-4 py-2 rounded-lg glass text-sm text-red-400 hover:bg-red-500/10 transition-all" %>
  </div>
</div>
