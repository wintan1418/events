<% content_for(:page_title) { "Admin Dashboard" } %>

<div class="space-y-8">
  <!-- Welcome Header -->
  <div class="relative overflow-hidden rounded-2xl border border-white/[0.06] bg-gradient-to-r from-gold-500/10 via-white/[0.03] to-transparent p-8">
    <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/5 rounded-full -translate-y-32 translate-x-32"></div>
    <div class="absolute bottom-0 right-20 w-32 h-32 bg-gold-400/5 rounded-full translate-y-16"></div>
    <div class="relative flex items-center justify-between">
      <div>
        <p class="text-sm text-gold-400 font-medium">Admin Control Center</p>
        <h1 class="text-3xl font-bold text-white mt-1">Welcome, <%= current_user.first_name %></h1>
        <p class="text-gray-400 mt-2 text-sm">Manage your organization, team, and events from here.</p>
      </div>
      <div class="hidden lg:flex items-center gap-3">
        <%= link_to admin_events_path, class: "flex items-center gap-2 px-4 py-2 rounded-xl bg-white/[0.05] border border-white/[0.08] text-sm text-gray-300 hover:text-white hover:border-gold-500/20 transition-all" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
          Events
        <% end %>
        <%= link_to admin_users_path, class: "flex items-center gap-2 px-4 py-2 rounded-xl bg-white/[0.05] border border-white/[0.08] text-sm text-gray-300 hover:text-white hover:border-gold-500/20 transition-all" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          Team
        <% end %>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <%= render "components/stat_card", label: "Total Events", value: @total_events,
        icon_path: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" %>
    <%= render "components/stat_card", label: "Active Planners", value: @active_planners,
        icon_path: "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z", color: "emerald" %>
    <%= render "components/stat_card", label: "Active Clients", value: @active_clients,
        icon_path: "M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z", color: "blue" %>
    <%= render "components/stat_card", label: "Active Vendors", value: @active_vendors,
        icon_path: "M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z", color: "purple" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Events Table (2/3 width) -->
    <div class="lg:col-span-2">
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
        <div class="flex items-center justify-between p-6 pb-4">
          <div>
            <h3 class="text-lg font-semibold text-white">Upcoming Events</h3>
            <p class="text-xs text-gray-500 mt-1"><%= @events_this_month %> events this month</p>
          </div>
          <%= link_to admin_events_path, class: "flex items-center gap-1.5 text-sm text-gold-400 hover:text-gold-300 transition-colors" do %>
            <span>View All</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <% end %>
        </div>

        <% if @upcoming_events.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-y border-white/[0.06]">
                  <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Event</th>
                  <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Client</th>
                  <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                  <th class="px-6 py-3 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                </tr>
              </thead>
              <tbody>
                <% @upcoming_events.each do |event| %>
                  <tr class="border-b border-white/[0.03] hover:bg-white/[0.02] transition-colors">
                    <td class="px-6 py-4">
                      <%= link_to admin_event_path(event), class: "group" do %>
                        <p class="font-medium text-white group-hover:text-gold-400 transition-colors"><%= event.title %></p>
                        <p class="text-[11px] text-gray-500 mt-0.5"><%= event.event_type.humanize %> &middot; <%= event.planner&.full_name || "Unassigned" %></p>
                      <% end %>
                    </td>
                    <td class="px-6 py-4">
                      <% if event.client %>
                        <div class="flex items-center gap-2">
                          <div class="w-6 h-6 rounded-md bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-[10px] font-bold">
                            <%= event.client.initials %>
                          </div>
                          <span class="text-gray-300 text-xs"><%= event.client.full_name %></span>
                        </div>
                      <% else %>
                        <span class="text-gray-600 text-xs">No client</span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 text-gray-400 text-xs"><%= event.event_date&.strftime("%b %d, %Y") || "TBD" %></td>
                    <td class="px-6 py-4"><%= render "components/badge", status: event.status %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-8 text-center">
            <p class="text-gray-500 text-sm">No upcoming events</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Team Members (1/3 width) -->
    <div>
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-white/[0.06]">
          <h3 class="text-sm font-semibold text-white">Team Members</h3>
          <%= link_to admin_users_path, class: "text-xs text-gold-400 hover:text-gold-300 transition-colors" do %>
            View All
          <% end %>
        </div>
        <div class="p-3 space-y-1">
          <% @team_members.each do |member| %>
            <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/[0.04] transition-colors">
              <% avatar_color = case member.role; when 'admin' then '#f59e0b'; when 'planner' then '#10b981'; when 'client' then '#3b82f6'; else '#a855f7'; end %>
              <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold flex-shrink-0" style="background: linear-gradient(to bottom right, <%= avatar_color %>, <%= avatar_color %>dd); color: <%= member.admin? ? '#000' : '#fff' %>">
                <%= member.initials %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm text-white truncate"><%= member.full_name %></p>
                <p class="text-[11px] text-gray-500"><%= member.role.humanize %></p>
              </div>
              <div class="w-2 h-2 rounded-full" style="background-color: <%= member.active? ? '#10b981' : '#6b7280' %>"></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
